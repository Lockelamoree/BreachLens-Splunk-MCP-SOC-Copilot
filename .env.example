# BreachLens local defaults. Copy to .env and replace values locally.

# Backend mode: rest, mcp, or sample. rest uses the local Splunk container.
BREACHLENS_MODE=rest
BREACHLENS_API_HOST=127.0.0.1
BREACHLENS_API_PORT=8080
BREACHLENS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local Splunk REST/live-data mode.
SPLUNK_BASE_URL=https://localhost:18089
SPLUNK_UI_URL=http://127.0.0.1:18000
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=
SPLUNK_TOKEN=
SPLUNK_VERIFY_TLS=false
SPLUNK_INDEX=breachlens

# Splunk MCP Server final-demo mode. Generate this in the Splunk MCP Server app; never commit it.
SPLUNK_MCP_URL=
SPLUNK_MCP_TOKEN=
SPLUNK_MCP_VERIFY_TLS=false

# Optional provider-flexible AI runtime. Set OLLAMA_BASE_URL to enable the NiNa demo model.
OLLAMA_BASE_URL=
OLLAMA_MODEL=hf.co/LockeLamora2077/NiNa:latest
OLLAMA_TIMEOUT_SECONDS=120
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Frontend.
VITE_API_BASE_URL=http://localhost:8080
